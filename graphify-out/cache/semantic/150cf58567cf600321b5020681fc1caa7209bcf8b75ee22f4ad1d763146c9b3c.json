{"nodes": [{"id": "readme_private_bedlam_research_platform", "label": "Bedlam Research Platform", "file_type": "document", "source_file": "README-PRIVATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": "Aiden Tran", "contributor": null}, {"id": "readme_private_agentcontext", "label": "AgentContext", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "37", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_llmstrategiclayer", "label": "LLM Strategic Layer", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "43", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Runs asynchronously every ~2s to avoid blocking the tick loop. Intentional design: the server must never wait for LLM responses to preserve real-time agent behavior validity in research findings."}, {"id": "readme_private_rlcombatlayer", "label": "RL Combat Layer", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "48", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Uses PPO (OpenPVP, BridgeFight, BedDefense) \u2014 standard choice for discrete action spaces; goal is functional combat, not state-of-the-art RL. BridgeFight and BedDefense use LSTM for temporal patterns."}, {"id": "readme_private_scriptedtools", "label": "Scripted Tools", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "53", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_reactiveinterruptlayer", "label": "Reactive Interrupt Layer", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "59", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hardcoded survival behaviors that always run every tick at highest priority regardless of other layers. Not optional or deferrable."}, {"id": "readme_private_mineflayerbot", "label": "Mineflayer Bot", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "65", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_naturallangncomm", "label": "Natural Language Agent Communication", "file_type": "rationale", "source_file": "README-PRIVATE.md", "source_location": "72", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Agents communicate via Minecraft chat in natural language rather than structured schemas. Intentional research decision: the research question concerns what agents choose to say and how that evolves \u2014 structured vocab would answer a different question. The messiness is the point."}, {"id": "readme_private_researchquestion", "label": "Research Question: Emergent Behavior Under Competitive Pressure", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "18", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_rlenv", "label": "rl-env (Python)", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "87", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Separate from rl-pvp so the physics simulation can remain stable while training is iterated on. No Mineflayer dependency \u2014 runs headless for fast parallel training."}, {"id": "readme_private_rlpvp", "label": "rl-pvp (Python)", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "87", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_dashboard", "label": "dashboard (JS)", "file_type": "concept", "source_file": "README-PRIVATE.md", "source_location": "87", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_private_research_repo", "la